            Tertiary = "#F59E0B",
            AppbarBackground = "#4F46E5",
            Background = "#F8FAFC",
            Surface = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#334155",
            TextPrimary = "#1E293B",
