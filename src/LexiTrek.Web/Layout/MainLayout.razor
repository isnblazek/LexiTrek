@inherits LayoutComponentBase
@inject AuthApiService AuthService
@inject DictionaryStateService DictState
@inject NavigationManager Navigation
@implements IDisposable

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <MudAppBar Elevation="0" Style="background: #4F46E5; border-bottom: 1px solid rgba(255,255,255,0.1);">
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                               OnClick="@ToggleDrawer" />
                <MudText Typo="Typo.h6" Class="ml-3" Style="font-weight: 800; letter-spacing: -0.5px;">LexiTrek</MudText>

                @if (DictState.Dictionaries.Any())
                {
                    <MudSelect T="long?" Value="DictState.SelectedDictionaryId" ValueChanged="OnDictionaryChanged"
                               Class="ml-4 appbar-dictionary-select" Variant="Variant.Outlined"
                               Dense="true" Margin="Margin.Dense"
                               Style="max-width: 280px; color: white;">
                        @foreach (var dict in DictState.Dictionaries)
                        {
                            <MudSelectItem T="long?" Value="@((long?)dict.Id)">@dict.SourceLangName ↔ @dict.TargetLangName</MudSelectItem>
                        }
                    </MudSelect>
                }

                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Inherit"
                               Href="/settings" />
                <MudMenu Icon="@Icons.Material.Filled.Person" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight">
                    <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="LogoutAsync">Odhlásit se</MudMenuItem>
                </MudMenu>
            </MudAppBar>

            <MudDrawer @bind-Open="_drawerOpen" Elevation="0" ClipMode="DrawerClipMode.Always"
                       Style="border-right: 1px solid #E2E8F0;">
                <MudNavMenu Class="pt-2">
                    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                        Dashboard
                    </MudNavLink>
                    <MudNavLink Href="/groups" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Folder">
                        Moje skupiny
                    </MudNavLink>
                    <MudNavLink Href="/groups/public" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Public">
                        Veřejné skupiny
                    </MudNavLink>
                    <MudDivider Class="my-2" />
                    <MudNavLink Href="/training/setup" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.FitnessCenter">
                        Trénink
                    </MudNavLink>
                </MudNavMenu>
            </MudDrawer>

            <MudMainContent Class="pa-6 pt-16" Style="background: #F8FAFC; min-height: 100vh;">
                @Body
            </MudMainContent>
        </MudLayout>
    </Authorized>
    <NotAuthorized>
        @Body
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _drawerOpen = true;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        DictState.OnChange += StateHasChanged;
        if (AuthState != null)
        {
            var state = await AuthState;
            if (state.User.Identity?.IsAuthenticated == true)
            {
                await DictState.LoadAsync();
            }
        }
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void OnDictionaryChanged(long? newId) => DictState.SetSelectedDictionary(newId);

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/");
    }

    public void Dispose() => DictState.OnChange -= StateHasChanged;
}
