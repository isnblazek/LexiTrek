@page "/training/errors"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject TrainingApiService TrainingService
@inject DictionaryStateService DictState
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Problematická slovíčka - LexiTrek</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <div class="d-flex align-center gap-2 mb-3 mt-4">
        <MudText Typo="Typo.h5" Style="font-weight: 700;">Problematická slovíčka</MudText>
        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">
            @_entries.Count slovíček
        </MudChip>
    </div>

    <div class="d-flex align-center gap-2 mb-4 py-2" style="position: sticky; top: 64px; z-index: 10; background: #F8FAFC;">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                   Href="/training/setup?filter=errors" StartIcon="@Icons.Material.Filled.FitnessCenter"
                   Style="text-transform: none;">
            Trénovat chyby
        </MudButton>
        <MudTextField @bind-Value="_searchText" Placeholder="Hledat..." Variant="Variant.Outlined"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Margin="Margin.Dense" Immediate="true" Class="flex-grow-1" />
    </div>

    <MudTable Items="_entries" Hover="true" Striped="true" Elevation="1"
              Style="border-radius: 12px;" Filter="FilterFunc">
        <HeaderContent>
            <MudTh Style="font-weight: 700;">Výraz</MudTh>
            <MudTh Style="font-weight: 700;">Překlad</MudTh>
            <MudTh Style="font-weight: 700;">Chybovost</MudTh>
            <MudTh Style="font-weight: 700;">Opakování</MudTh>
            <MudTh Style="font-weight: 700;">Poslední</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Výraz"><strong>@context.SourceText</strong></MudTd>
            <MudTd DataLabel="Překlad">@context.TargetText</MudTd>
            <MudTd DataLabel="Chybovost">
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.ErrorRate > 60 ? Color.Error : Color.Warning)"
                         Variant="Variant.Filled">
                    @context.ErrorRate % (@context.IncorrectCount/@context.TotalReviews)
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Opakování">@context.TotalReviews</MudTd>
            <MudTd DataLabel="Poslední">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @(context.LastReviewedAt?.ToString("d.M.yyyy") ?? "—")
                </MudText>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <div class="pa-8 text-center">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" Class="mb-2" />
                <MudText Color="Color.Secondary">Žádná problematická slovíčka!</MudText>
            </div>
        </NoRecordsContent>
    </MudTable>
}

@code {
    private List<ErrorEntryDto> _entries = [];
    private bool _loading = true;
    private string _searchText = "";

    protected override async Task OnInitializedAsync()
    {
        DictState.OnChange += OnDictionaryChanged;
        _entries = await TrainingService.GetErrorEntriesAsync(DictState.SelectedDictionaryId);
        _loading = false;
    }

    private bool FilterFunc(ErrorEntryDto entry)
    {
        if (string.IsNullOrWhiteSpace(_searchText)) return true;
        return entry.SourceText.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || entry.TargetText.Contains(_searchText, StringComparison.OrdinalIgnoreCase);
    }

    private async void OnDictionaryChanged()
    {
        _entries = await TrainingService.GetErrorEntriesAsync(DictState.SelectedDictionaryId);
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() => DictState.OnChange -= OnDictionaryChanged;
}
