@inject WordApiService WordService
@inject TagApiService TagService

<MudDialog>
    <TitleContent>Upravit slovíčko</TitleContent>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="_sourceText" Label="@SourceLangName" Variant="Variant.Outlined" Class="mb-3" Required="true" />
            <MudTextField @bind-Value="_targetText" Label="@TargetLangName" Variant="Variant.Outlined" Class="mb-3" Required="true" />
            <div class="d-flex align-center mb-3">
                <MudTextField @bind-Value="_tagsInput" Label="Tagy" Variant="Variant.Outlined"
                              Placeholder="jídlo, B2..." Class="flex-grow-1" />
                @if (_allTags.Any())
                {
                    <MudMenu Icon="@Icons.Material.Filled.ArrowDropDown" Size="Size.Small" Dense="true"
                             AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        @foreach (var tag in _allTags)
                        {
                            <MudMenuItem OnClick="@(() => AppendTag(tag.Name))">@tag.Name</MudMenuItem>
                        }
                    </MudMenu>
                }
            </div>
            <MudTextField @bind-Value="_notes" Label="Poznámka" Variant="Variant.Outlined" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Zrušit</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync" Disabled="_saving">Uložit</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public DictionaryEntryDto Entry { get; set; } = default!;
    [Parameter] public string SourceLangName { get; set; } = "Výraz";
    [Parameter] public string TargetLangName { get; set; } = "Překlad";

    private MudForm _form = default!;
    private bool _saving;
    private string _sourceText = "";
    private string _targetText = "";
    private string? _notes;
    private string _tagsInput = "";
    private List<TagDto> _allTags = [];

    protected override async Task OnInitializedAsync()
    {
        _sourceText = Entry.SourceText;
        _targetText = Entry.TargetText;
        _notes = Entry.Notes;
        _tagsInput = string.Join(", ", Entry.Tags.Select(t => t.Name));
        _allTags = await TagService.GetTagsAsync();
    }

    private void AppendTag(string tagName)
    {
        var existing = _tagsInput
            .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .ToList();
        if (!existing.Contains(tagName, StringComparer.OrdinalIgnoreCase))
        {
            _tagsInput = existing.Count > 0 ? $"{_tagsInput.TrimEnd().TrimEnd(',')}, {tagName}" : tagName;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SaveAsync()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        _saving = true;

        var updated = await WordService.UpdateEntryAsync(Entry.Id, new UpdateEntryDto(_sourceText, _targetText, _notes));
        if (updated == null)
        {
            _saving = false;
            return;
        }

        var desiredTags = _tagsInput
            .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        var resolvedTags = new List<TagDto>();
        foreach (var tagName in desiredTags)
        {
            var existing = _allTags.FirstOrDefault(t => string.Equals(t.Name, tagName, StringComparison.OrdinalIgnoreCase));
            if (existing != null)
            {
                resolvedTags.Add(existing);
            }
            else
            {
                var created = await TagService.CreateTagAsync(new CreateTagDto(tagName));
                if (created != null)
                {
                    resolvedTags.Add(created);
                    _allTags.Add(created);
                }
            }
        }

        var currentTagIds = Entry.Tags.Select(t => t.Id).ToHashSet();
        var desiredTagIds = resolvedTags.Select(t => t.Id).ToHashSet();

        var toAdd = desiredTagIds.Except(currentTagIds).ToList();
        var toRemove = currentTagIds.Except(desiredTagIds).ToList();

        if (toAdd.Count > 0)
            await TagService.AssignTagsAsync(Entry.Id, new AssignTagsDto(toAdd));

        foreach (var tagId in toRemove)
            await TagService.RemoveTagAsync(Entry.Id, tagId);

        var resultEntry = updated with { Tags = resolvedTags };
        MudDialog.Close(DialogResult.Ok(resultEntry));
    }
}
