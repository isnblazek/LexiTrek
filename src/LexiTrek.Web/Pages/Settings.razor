@page "/settings"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject DictionaryApiService DictionaryService
@inject DictionaryStateService DictState
@inject ISnackbar Snackbar

<PageTitle>Nastavení - LexiTrek</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Nastavení</MudText>

<MudText Typo="Typo.h5" Class="mb-3">Slovníky</MudText>

<MudCard Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h6" Class="mb-2">Nový slovník</MudText>
        <MudGrid>
            <MudItem xs="12" sm="5">
                <MudSelect @bind-Value="_sourceLanguage" Label="Zdrojový jazyk" Variant="Variant.Outlined"
                           ToStringFunc="@(l => l.HasValue ? LanguageHelper.GetLabel(l.Value) : "")">
                    @foreach (var lang in Enum.GetValues<Language>())
                    {
                        <MudSelectItem T="Language?" Value="@((Language?)lang)">@LanguageHelper.GetLabel(lang)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="5">
                <MudSelect @bind-Value="_targetLanguage" Label="Cílový jazyk" Variant="Variant.Outlined"
                           ToStringFunc="@(l => l.HasValue ? LanguageHelper.GetLabel(l.Value) : "")">
                    @foreach (var lang in Enum.GetValues<Language>())
                    {
                        <MudSelectItem T="Language?" Value="@((Language?)lang)">@LanguageHelper.GetLabel(lang)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleCreate"
                           Disabled="_creating" FullWidth="true">Vytvořit</MudButton>
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (!DictState.Dictionaries.Any())
{
    <MudAlert Severity="Severity.Info">Žádné slovníky k zobrazení.</MudAlert>
}
else
{
    <MudGrid>
        @foreach (var dict in DictState.Dictionaries)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard>
                    <MudCardContent>
                        <div class="d-flex justify-space-between align-center">
                            <MudText Typo="Typo.h6">@LanguageHelper.GetDisplayName((Language)dict.SourceLanguage) <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" /> @LanguageHelper.GetDisplayName((Language)dict.TargetLanguage)</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(() => HandleDelete(dict.Id))" />
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private bool _loading = true;
    private bool _creating;
    private Language? _sourceLanguage;
    private Language? _targetLanguage;

    protected override async Task OnInitializedAsync()
    {
        await DictState.LoadAsync();
        _loading = false;
    }

    private async Task HandleCreate()
    {
        if (_sourceLanguage == null || _targetLanguage == null) return;

        _creating = true;
        var result = await DictionaryService.CreateDictionaryAsync(
            new CreateDictionaryDto((int)_sourceLanguage.Value, (int)_targetLanguage.Value));

        if (result != null)
        {
            _sourceLanguage = null;
            _targetLanguage = null;
            await DictState.LoadAsync();
            Snackbar.Add("Slovník vytvořen!", Severity.Success);
        }
        else
        {
            Snackbar.Add("Chyba při vytváření slovníku.", Severity.Error);
        }

        _creating = false;
    }

    private async Task HandleDelete(Guid id)
    {
        if (await DictionaryService.DeleteDictionaryAsync(id))
        {
            await DictState.LoadAsync();
            Snackbar.Add("Slovník smazán.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Nelze smazat tento slovník.", Severity.Error);
        }
    }
}
