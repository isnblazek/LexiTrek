@page "/settings"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject DictionaryApiService DictionaryService
@inject LanguageApiService LanguageService
@inject DictionaryStateService DictState
@inject ISnackbar Snackbar

<PageTitle>Nastavení - LexiTrek</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Nastavení</MudText>

<MudText Typo="Typo.h5" Class="mb-3">Slovníky</MudText>

<MudCard Class="mb-4">
    <MudCardContent>
        <MudText Typo="Typo.h6" Class="mb-2">Nový slovník</MudText>
        <MudGrid>
            <MudItem xs="12" sm="5">
                <MudSelect @bind-Value="_sourceLangId" Label="Zdrojový jazyk" Variant="Variant.Outlined"
                           ToStringFunc="@(id => _languages.FirstOrDefault(l => l.Id == id)?.Name ?? "")">
                    @foreach (var lang in _languages)
                    {
                        <MudSelectItem Value="lang.Id">@lang.Code – @lang.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="5">
                <MudSelect @bind-Value="_targetLangId" Label="Cílový jazyk" Variant="Variant.Outlined"
                           ToStringFunc="@(id => _languages.FirstOrDefault(l => l.Id == id)?.Name ?? "")">
                    @foreach (var lang in _languages)
                    {
                        <MudSelectItem Value="lang.Id">@lang.Code – @lang.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleCreate"
                           Disabled="_creating" FullWidth="true">Vytvořit</MudButton>
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (!DictState.Dictionaries.Any())
{
    <MudAlert Severity="Severity.Info">Žádné slovníky k zobrazení.</MudAlert>
}
else
{
    <MudGrid>
        @foreach (var dict in DictState.Dictionaries)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard>
                    <MudCardContent>
                        <div class="d-flex justify-space-between align-center">
                            <MudText Typo="Typo.h6">@dict.SourceLangName <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" /> @dict.TargetLangName</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(() => HandleDelete(dict.Id))" />
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private bool _loading = true;
    private bool _creating;
    private int _sourceLangId;
    private int _targetLangId;
    private List<LanguageDto> _languages = [];

    protected override async Task OnInitializedAsync()
    {
        _languages = await LanguageService.GetLanguagesAsync();
        await DictState.LoadAsync();
        _loading = false;
    }

    private async Task HandleCreate()
    {
        if (_sourceLangId == 0 || _targetLangId == 0) return;

        _creating = true;

        var result = await DictionaryService.CreateDictionaryAsync(
            new CreateDictionaryDto(_sourceLangId, _targetLangId));

        if (result != null)
        {
            await DictState.LoadAsync();
            Snackbar.Add("Slovník vytvořen!", Severity.Success);
        }
        else
        {
            Snackbar.Add("Chyba při vytváření slovníku.", Severity.Error);
        }

        _creating = false;
    }

    private async Task HandleDelete(long id)
    {
        if (await DictionaryService.DeleteDictionaryAsync(id))
        {
            await DictState.LoadAsync();
            Snackbar.Add("Slovník smazán.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Nelze smazat tento slovník.", Severity.Error);
        }
    }
}
