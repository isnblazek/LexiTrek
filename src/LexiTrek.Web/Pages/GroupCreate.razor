@page "/groups/create"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject GroupApiService GroupService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Nová skupina - LexiTrek</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small">
    <MudText Typo="Typo.h4" Class="mb-4">Nová skupina</MudText>

    <MudCard>
        <MudCardContent>
            <MudTextField @bind-Value="_name" Label="Název" Variant="Variant.Outlined" Class="mb-3" Required="true" />
            <MudTextField @bind-Value="_description" Label="Popis" Variant="Variant.Outlined" Class="mb-3" Lines="3" />
            <MudSelect @bind-Value="_visibility" Label="Viditelnost" Variant="Variant.Outlined">
                <MudSelectItem Value="0">Soukromá</MudSelectItem>
                <MudSelectItem Value="1">Veřejná</MudSelectItem>
            </MudSelect>
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleCreate" Disabled="_loading">
                Vytvořit
            </MudButton>
            <MudButton Variant="Variant.Text" Href="/groups">Zrušit</MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private string _name = "";
    private string? _description;
    private int _visibility;
    private bool _loading;

    private async Task HandleCreate()
    {
        if (string.IsNullOrWhiteSpace(_name)) return;

        _loading = true;
        var result = await GroupService.CreateGroupAsync(new CreateGroupDto(_name, _description, _visibility));

        if (result != null)
        {
            Snackbar.Add("Skupina vytvořena!", Severity.Success);
            Navigation.NavigateTo($"/groups/{result.Id}");
        }
        else
        {
            Snackbar.Add("Chyba při vytváření skupiny.", Severity.Error);
        }

        _loading = false;
    }
}
