@page "/groups/create"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject GroupApiService GroupService
@inject DictionaryApiService DictionaryService
@inject DictionaryStateService DictState
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Nová skupina - LexiTrek</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small">
    <MudText Typo="Typo.h4" Class="mb-4">Nová skupina</MudText>

    <MudCard>
        <MudCardContent>
            <MudTextField @bind-Value="_name" Label="Název" Variant="Variant.Outlined" Class="mb-3" Required="true" />
            <MudTextField @bind-Value="_description" Label="Popis" Variant="Variant.Outlined" Class="mb-3" Lines="3" />
            <MudSelect @bind-Value="_dictionaryId" Label="Slovník" Variant="Variant.Outlined" Class="mb-3"
                       Required="true" ToStringFunc="@(id => _dictionaries.FirstOrDefault(d => d.Id == id) is {} d ? $"{d.SourceLanguage} ↔ {d.TargetLanguage}" : "")">
                @foreach (var dict in _dictionaries)
                {
                    <MudSelectItem Value="dict.Id">@dict.SourceLanguage ↔ @dict.TargetLanguage</MudSelectItem>
                }
            </MudSelect>
            <MudSelect @bind-Value="_visibility" Label="Viditelnost" Variant="Variant.Outlined">
                <MudSelectItem Value="0">Soukromá</MudSelectItem>
                <MudSelectItem Value="1">Veřejná</MudSelectItem>
            </MudSelect>
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleCreate" Disabled="_loading">
                Vytvořit
            </MudButton>
            <MudButton Variant="Variant.Text" Href="/groups">Zrušit</MudButton>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private string _name = "";
    private string? _description;
    private int _visibility;
    private Guid _dictionaryId;
    private bool _loading;
    private List<DictionaryListDto> _dictionaries = [];

    protected override async Task OnInitializedAsync()
    {
        _dictionaries = await DictionaryService.GetDictionariesAsync();
        if (DictState.SelectedDictionaryId.HasValue && _dictionaries.Any(d => d.Id == DictState.SelectedDictionaryId.Value))
            _dictionaryId = DictState.SelectedDictionaryId.Value;
        else if (_dictionaries.Any())
            _dictionaryId = _dictionaries.First().Id;
    }

    private async Task HandleCreate()
    {
        if (string.IsNullOrWhiteSpace(_name) || _dictionaryId == Guid.Empty) return;

        _loading = true;
        var result = await GroupService.CreateGroupAsync(new CreateGroupDto(_name, _description, _visibility, _dictionaryId));

        if (result != null)
        {
            Snackbar.Add("Skupina vytvořena!", Severity.Success);
            Navigation.NavigateTo($"/groups/{result.Id}");
        }
        else
        {
            Snackbar.Add("Chyba při vytváření skupiny.", Severity.Error);
        }

        _loading = false;
    }
}
