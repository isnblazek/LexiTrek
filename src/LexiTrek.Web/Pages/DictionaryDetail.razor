@page "/groups/{Id:long}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject GroupApiService GroupService
@inject WordApiService WordService
@inject TagApiService TagService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject TrainingApiService TrainingService
@inject DictionaryStateService DictState

<PageTitle>@(_group?.Name ?? "Skupina") - LexiTrek</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_group == null)
{
    <MudAlert Severity="Severity.Error">Skupina nenalezena.</MudAlert>
}
else
{
    @if (_editing)
    {
        <MudCard Elevation="2" Class="mb-4" Style="border-radius: 16px;">
            <MudCardContent Class="pa-6">
                <MudText Typo="Typo.h6" Class="mb-4">Upravit skupinu</MudText>
                <MudForm @ref="_form">
                    <MudTextField @bind-Value="_editName" Label="Název skupiny" Variant="Variant.Outlined" Class="mb-4"
                                  Required="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Label" />
                    <MudTextField @bind-Value="_editDescription" Label="Popis (volitelný)" Variant="Variant.Outlined" Class="mb-6" Lines="3" />

                    <MudPaper Elevation="0" Class="pa-4" Style="background: #F8FAFC; border-radius: 12px;">
                        <div class="d-flex justify-space-between align-center">
                            <div>
                                <div class="d-flex align-center gap-2 mb-1">
                                    <MudIcon Icon="@(_editIsPublic ? Icons.Material.Filled.Public : Icons.Material.Filled.Lock)"
                                             Color="@(_editIsPublic ? Color.Success : Color.Default)" Size="Size.Small" />
                                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                                        @(_editIsPublic ? "Veřejná skupina" : "Soukromá skupina")
                                    </MudText>
                                </div>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @(_editIsPublic
                                        ? "Ostatní uživatelé ji uvidí a mohou si ji převzít."
                                        : "Vidíte ji pouze vy. Můžete ji kdykoli zveřejnit.")
                                </MudText>
                            </div>
                            <MudSwitch @bind-Value="_editIsPublic" Color="Color.Success" />
                        </div>
                    </MudPaper>
                </MudForm>
            </MudCardContent>
            <MudCardActions Class="pa-6 pt-0 d-flex gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveEditAsync" Disabled="_saving"
                           Style="text-transform: none;">Uložit</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="CancelEdit"
                           Style="text-transform: none;">Zrušit</MudButton>
            </MudCardActions>
        </MudCard>
    }
    else
    {
        @* ── Kompaktní hlavička ── *@
        <div class="d-flex align-center justify-space-between mb-3 mt-4">
            <div class="d-flex align-center gap-2">
                <MudText Typo="Typo.h5" Style="font-weight: 700;">@_group.Name</MudText>
                <MudMenu Icon="@Icons.Material.Outlined.Info" Size="Size.Small" Color="Color.Default"
                         AnchorOrigin="Origin.BottomLeft" Dense="true">
                    <div class="pa-4" style="min-width: 280px;">
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Class="mb-2">
                            @_group.SourceLangName ↔ @_group.TargetLangName
                        </MudChip>
                        <div class="d-flex align-center gap-2 mb-2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Autor:</MudText>
                            @if (!_group.IsOwner)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default"
                                         Href="@($"/groups/public?search={Uri.EscapeDataString(_group.OwnerDisplayName)}")"
                                         Icon="@Icons.Material.Filled.Person">
                                    @_group.OwnerDisplayName
                                </MudChip>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption">@_group.OwnerDisplayName</MudText>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(_group.Description))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@_group.Description</MudText>
                        }
                    </div>
                </MudMenu>
                @if (_group.IsOwner)
                {
                    <MudTooltip Text="@(_group.IsPublic ? "Skupina je veřejná — ostatní ji mohou převzít" : "Skupina je soukromá — vidíte ji pouze vy")">
                        <MudSwitch T="bool" Value="_group.IsPublic" ValueChanged="OnPublicToggled" Color="Color.Success"
                                   Label="@(_group.IsPublic ? "Veřejná" : "Soukromá")" />
                    </MudTooltip>
                }
                else if (_group.IsPublic)
                {
                    <MudTooltip Text="Veřejná skupina">
                        <MudIcon Icon="@Icons.Material.Filled.Public" Size="Size.Small" Color="Color.Success" />
                    </MudTooltip>
                }
            </div>
            @if (_group.IsOwner)
            {
                <div class="d-flex gap-1">
                    <MudTooltip Text="Upravit skupinu">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="StartEdit" />
                    </MudTooltip>
                    <MudTooltip Text="Smazat skupinu">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="DeleteGroupAsync" />
                    </MudTooltip>
                </div>
            }
        </div>

        @* ── Akční lišta + vyhledávání ── *@
        <div class="d-flex align-center gap-2 mb-4 py-2" style="position: sticky; top: 64px; z-index: 10; background: #F8FAFC;">
            @if (_group.IsOwner)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           OnClick="@(() => _showAddEntry = !_showAddEntry)" StartIcon="@Icons.Material.Filled.Add"
                           Style="text-transform: none;">
                    Přidat slovíčko
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           OnClick="OpenTrainingDialogAsync" StartIcon="@Icons.Material.Filled.FitnessCenter"
                           Style="text-transform: none;">
                    Trénink
                </MudButton>
                @if (_selectedEntries.Any())
                {
                    <MudMenu Label="@($"Přidat do skupiny ({_selectedEntries.Count})")" Variant="Variant.Filled"
                             Color="Color.Secondary" Size="Size.Small" StartIcon="@Icons.Material.Filled.CreateNewFolder"
                             AnchorOrigin="Origin.BottomLeft" Dense="true"
                             Style="text-transform: none;">
                        @foreach (var g in _userGroups.Where(g => g.Id != Id))
                        {
                            <MudMenuItem OnClick="@(() => AddToGroupAsync(g.Id))">@g.Name</MudMenuItem>
                        }
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Filled.Add"
                               OnClick="@(() => Navigation.NavigateTo($"/groups/create?entryIds={string.Join(",", _selectedEntries.Select(e => e.Id))}"))">
                        Vytvořit novou skupinu
                    </MudMenuItem>
                    </MudMenu>
                }
            }
            else
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           OnClick="ForkGroupAsync" StartIcon="@Icons.Material.Filled.ContentCopy"
                           Style="text-transform: none;">
                    Převzít vše
                </MudButton>
                @if (_selectedEntries.Any())
                {
                    <MudMenu Label="@($"Převzít vybraná ({_selectedEntries.Count})")" Variant="Variant.Filled"
                             Color="Color.Secondary" Size="Size.Small" StartIcon="@Icons.Material.Filled.ContentCopy"
                             AnchorOrigin="Origin.BottomLeft" Dense="true"
                             Style="text-transform: none;">
                        @foreach (var g in _userGroups)
                        {
                            <MudMenuItem OnClick="@(() => AdoptSelectedToGroupAsync(g.Id))">@g.Name</MudMenuItem>
                        }
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Filled.Add" Href="/groups/create">Vytvořit novou skupinu</MudMenuItem>
                    </MudMenu>
                }
            }
            <MudTextField @bind-Value="_searchText" Placeholder="Hledat..." Variant="Variant.Outlined"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Margin="Margin.Dense" Immediate="true" Class="flex-grow-1" />
            <MudMenu Icon="@Icons.Material.Filled.FilterList" Size="Size.Small" Dense="true"
                     AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                     CloseOnContentClick="false">
                <MudMenuItem OnClick="@(() => _searchSource = !_searchSource)">
                    <div class="d-flex align-center gap-2">
                        <MudCheckBox T="bool" Value="_searchSource" Color="Color.Primary" Dense="true" Class="ma-0" />
                        <MudText Typo="Typo.body2">@(_group?.SourceLangName ?? "Výraz")</MudText>
                    </div>
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => _searchTarget = !_searchTarget)">
                    <div class="d-flex align-center gap-2">
                        <MudCheckBox T="bool" Value="_searchTarget" Color="Color.Primary" Dense="true" Class="ma-0" />
                        <MudText Typo="Typo.body2">@(_group?.TargetLangName ?? "Překlad")</MudText>
                    </div>
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => _searchTags = !_searchTags)">
                    <div class="d-flex align-center gap-2">
                        <MudCheckBox T="bool" Value="_searchTags" Color="Color.Primary" Dense="true" Class="ma-0" />
                        <MudText Typo="Typo.body2">Tagy</MudText>
                    </div>
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => _searchNotes = !_searchNotes)">
                    <div class="d-flex align-center gap-2">
                        <MudCheckBox T="bool" Value="_searchNotes" Color="Color.Primary" Dense="true" Class="ma-0" />
                        <MudText Typo="Typo.body2">Poznámka</MudText>
                    </div>
                </MudMenuItem>
            </MudMenu>
        </div>
    }

    @* ── Inline formulář pro přidání ── *@
    @if (_showAddEntry)
    {
        <MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-radius: 12px;">
            <div class="d-flex align-center gap-2">
                <MudTextField @bind-Value="_newSourceText" Label="@_group.SourceLangName" Variant="Variant.Outlined" Margin="Margin.Dense"
                              Style="flex: 3; min-width: 0;" />
                <MudTextField @bind-Value="_newTargetText" Label="@_group.TargetLangName" Variant="Variant.Outlined" Margin="Margin.Dense"
                              Style="flex: 3; min-width: 0;" />
                <div class="d-flex align-center" style="flex: 4; min-width: 0;">
                    <MudTextField @bind-Value="_newTagsInput" Label="Tagy" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Placeholder="jídlo, B2..." Class="flex-grow-1" />
                    @if (_tags.Any())
                    {
                        <MudMenu Icon="@Icons.Material.Filled.ArrowDropDown" Size="Size.Small" Dense="true"
                                 AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                            @foreach (var tag in _tags)
                            {
                                <MudMenuItem OnClick="@(() => AppendTag(tag.Name))">@tag.Name</MudMenuItem>
                            }
                        </MudMenu>
                    }
                </div>
                @if (!DrawerOpen)
                {
                    <MudTextField @bind-Value="_newNotes" Label="Poznámka" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Style="flex: 3; min-width: 0;" />
                }
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddEntryAsync"
                           Style="text-transform: none; height: 40px; flex-shrink: 0;">Přidat</MudButton>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               OnClick="@(() => _showAddEntry = false)" Style="height: 40px; width: 40px; flex-shrink: 0;" />
            </div>
        </MudPaper>
    }

    @* ── Tabulka slovíček ── *@
    <MudTable Items="_entries" Hover="true" Striped="true" Elevation="1"
              Style="border-radius: 12px;" MultiSelection="true"
              @bind-SelectedItems="_selectedEntries" Filter="FilterFunc">
        <HeaderContent>
            <MudTh Style="font-weight: 700;">@_group.SourceLangName</MudTh>
            <MudTh Style="font-weight: 700;">@_group.TargetLangName</MudTh>
            <MudTh Style="font-weight: 700;">Tagy</MudTh>
            <MudTh Style="font-weight: 700;">Poznámka</MudTh>
            @if (_group.IsOwner) { <MudTh Style="width: 80px;"></MudTh> }
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@_group.SourceLangName"><strong>@context.SourceText</strong></MudTd>
            <MudTd DataLabel="@_group.TargetLangName">@context.TargetText</MudTd>
            <MudTd DataLabel="Tagy">
                @foreach (var tag in context.Tags)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">@tag.Name</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Poznámka"><MudText Typo="Typo.body2" Color="Color.Secondary">@context.Notes</MudText></MudTd>
            @if (_group.IsOwner)
            {
                <MudTd Style="white-space: nowrap;">
                    <MudTooltip Text="Upravit">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => EditEntryAsync(context))" />
                    </MudTooltip>
                    <MudTooltip Text="Smazat">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="@(() => RemoveEntryAsync(context.Id))" Color="Color.Error" />
                    </MudTooltip>
                </MudTd>
            }
        </RowTemplate>
        <NoRecordsContent>
            <div class="pa-8 text-center">
                <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
                <MudText Color="Color.Secondary">Zatím žádná slovíčka. Přidejte první!</MudText>
            </div>
        </NoRecordsContent>
    </MudTable>
}

@code {
    [Parameter] public long Id { get; set; }
    [CascadingParameter(Name = "DrawerOpen")] private bool DrawerOpen { get; set; }

    private GroupDto? _group;
    private List<DictionaryEntryDto> _entries = [];
    private List<GroupListDto> _userGroups = [];
    private HashSet<DictionaryEntryDto> _selectedEntries = [];
    private bool _loading = true;
    private bool _showAddEntry;
    private string _newSourceText = "", _newTargetText = "";
    private string? _newNotes;
    private string _newTagsInput = "";
    private List<TagDto> _tags = [];
    private string _searchText = "";
    private bool _searchSource = true, _searchTarget = true, _searchTags = true, _searchNotes;
    private MudForm _form = default!;
    private bool _editing, _saving;
    private string _editName = "";
    private string? _editDescription;
    private bool _editIsPublic;

    protected override async Task OnInitializedAsync()
    {
        _group = await GroupService.GetGroupAsync(Id);
        if (_group != null)
        {
            _entries = await WordService.GetEntriesByGroupAsync(Id);
            _userGroups = await GroupService.GetUserGroupsAsync();
            _tags = await TagService.GetTagsAsync();
        }
        _loading = false;
    }

    private bool FilterFunc(DictionaryEntryDto entry)
    {
        if (string.IsNullOrWhiteSpace(_searchText)) return true;
        var s = _searchText;
        return (_searchSource && entry.SourceText.Contains(s, StringComparison.OrdinalIgnoreCase))
            || (_searchTarget && entry.TargetText.Contains(s, StringComparison.OrdinalIgnoreCase))
            || (_searchTags && entry.Tags.Any(t => t.Name.Contains(s, StringComparison.OrdinalIgnoreCase)))
            || (_searchNotes && (entry.Notes?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false));
    }

    private async Task AdoptSelectedToGroupAsync(long groupId)
    {
        var targetGroup = _userGroups.FirstOrDefault(g => g.Id == groupId);
        var dictId = targetGroup?.DictionaryId ?? DictState.SelectedDictionaryId;
        if (!dictId.HasValue) return;

        var count = 0;
        foreach (var entry in _selectedEntries)
        {
            await WordService.AddEntryAsync(dictId.Value, new CreateEntryDto(entry.SourceText, entry.TargetText, entry.Notes), groupId);
            count++;
        }
        await DictState.LoadAsync();
        Snackbar.Add($"{count} slovíček převzato do \"{targetGroup?.Name}\"", Severity.Success);
        _selectedEntries.Clear();
    }

    private async Task AddToGroupAsync(long groupId)
    {
        var count = 0;
        foreach (var entry in _selectedEntries)
        {
            await GroupService.AddEntryToGroupAsync(groupId, entry.Id);
            count++;
        }
        var targetGroup = _userGroups.FirstOrDefault(g => g.Id == groupId);
        Snackbar.Add($"{count} slovíček přidáno do \"{targetGroup?.Name}\"", Severity.Success);
        _selectedEntries.Clear();
    }

    private void StartEdit() { _editName = _group!.Name; _editDescription = _group.Description; _editIsPublic = _group.IsPublic; _editing = true; }
    private void CancelEdit() => _editing = false;

    private async Task SaveEditAsync()
    {
        await _form.Validate(); if (!_form.IsValid) return;
        _saving = true;
        var result = await GroupService.UpdateGroupAsync(Id, new UpdateGroupDto(_editName, _editDescription, _editIsPublic));
        if (result != null) { _group = result; _editing = false; Snackbar.Add("Skupina upravena!", Severity.Success); }
        else Snackbar.Add("Chyba při ukládání.", Severity.Error);
        _saving = false;
    }

    private async Task OnPublicToggled(bool newValue)
    {
        var result = await GroupService.UpdateGroupAsync(Id,
            new UpdateGroupDto(_group!.Name, _group.Description, newValue));
        if (result != null)
        {
            _group = result;
            Snackbar.Add(result.IsPublic ? "Skupina zveřejněna!" : "Skupina skryta.", Severity.Success);
        }
    }

    private async Task DeleteGroupAsync()
    {
        var result = await DialogService.ShowMessageBox("Smazat skupinu", "Opravdu chcete smazat tuto skupinu?", yesText: "Smazat", cancelText: "Zrušit");
        if (result == true)
        {
            if (await GroupService.DeleteGroupAsync(Id)) { await DictState.LoadAsync(); Snackbar.Add("Skupina smazána.", Severity.Success); Navigation.NavigateTo("/groups"); }
            else Snackbar.Add("Chyba při mazání skupiny.", Severity.Error);
        }
    }

    private async Task ForkGroupAsync()
    {
        var result = await GroupService.ForkGroupAsync(Id);
        if (result != null)
        {
            Snackbar.Add("Skupina převzata!", Severity.Success);
            Navigation.NavigateTo($"/groups/{result.Id}");
        }
        else
        {
            Snackbar.Add("Nepodařilo se převzít skupinu.", Severity.Error);
        }
    }

    private void AppendTag(string tagName)
    {
        var existing = _newTagsInput
            .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .ToList();
        if (!existing.Contains(tagName, StringComparer.OrdinalIgnoreCase))
        {
            _newTagsInput = existing.Count > 0 ? $"{_newTagsInput.TrimEnd().TrimEnd(',')}, {tagName}" : tagName;
        }
    }

    private async Task AddEntryAsync()
    {
        if (string.IsNullOrWhiteSpace(_newSourceText) || string.IsNullOrWhiteSpace(_newTargetText) || _group == null) return;
        var entry = await WordService.AddEntryAsync(_group.DictionaryId, new CreateEntryDto(_newSourceText, _newTargetText, _newNotes), Id);
        if (entry != null)
        {
            var desiredTags = _newTagsInput
                .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (desiredTags.Count > 0)
            {
                var resolvedTags = new List<TagDto>();
                foreach (var tagName in desiredTags)
                {
                    var existing = _tags.FirstOrDefault(t => string.Equals(t.Name, tagName, StringComparison.OrdinalIgnoreCase));
                    if (existing != null)
                    {
                        resolvedTags.Add(existing);
                    }
                    else
                    {
                        var created = await TagService.CreateTagAsync(new CreateTagDto(tagName));
                        if (created != null) { resolvedTags.Add(created); _tags.Add(created); }
                    }
                }
                if (resolvedTags.Count > 0)
                {
                    await TagService.AssignTagsAsync(entry.Id, new AssignTagsDto(resolvedTags.Select(t => t.Id).ToList()));
                    entry = entry with { Tags = resolvedTags };
                }
            }

            _entries.Add(entry);
            _newSourceText = ""; _newTargetText = ""; _newNotes = null; _newTagsInput = "";
            await DictState.LoadAsync();
            Snackbar.Add("Slovíčko přidáno!", Severity.Success);
        }
    }

    private async Task EditEntryAsync(DictionaryEntryDto entry)
    {
        var parameters = new DialogParameters<EditEntryDialog>
        {
            { x => x.Entry, entry },
            { x => x.SourceLangName, _group!.SourceLangName },
            { x => x.TargetLangName, _group!.TargetLangName }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<EditEntryDialog>("Upravit slovíčko", parameters, options);
        var result = await dialog.Result;
        if (!result!.Canceled) { var updated = (DictionaryEntryDto)result.Data!; var idx = _entries.FindIndex(e => e.Id == entry.Id); if (idx >= 0) _entries[idx] = updated; Snackbar.Add("Slovíčko upraveno!", Severity.Success); }
    }

    private async Task OpenTrainingDialogAsync()
    {
        var parameters = new DialogParameters<TrainingStartDialog> { { x => x.GroupId, Id } };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        await DialogService.ShowAsync<TrainingStartDialog>("Trénink", parameters, options);
    }

    private async Task RemoveEntryAsync(long entryId)
    {
        var result = await DialogService.ShowMessageBox("Smazat slovíčko", "Opravdu?", yesText: "Smazat", cancelText: "Zrušit");
        if (result == true && await WordService.RemoveEntryAsync(entryId)) { _entries.RemoveAll(e => e.Id == entryId); await DictState.LoadAsync(); Snackbar.Add("Slovíčko smazáno.", Severity.Success); }
    }
}
