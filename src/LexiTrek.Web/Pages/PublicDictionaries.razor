@page "/groups/public"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject GroupApiService GroupService
@inject DictionaryStateService DictState
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Veřejné skupiny - LexiTrek</PageTitle>

<MudText Typo="Typo.h5" Style="font-weight: 700;" Class="mt-4 mb-4">Veřejné skupiny</MudText>

<MudTextField @bind-Value="_search" Label="Hledat..." Variant="Variant.Outlined" Class="mb-4"
              Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
              OnKeyUp="HandleSearch" Immediate="true" Margin="Margin.Dense" />

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_result == null || !_result.Items.Any())
{
    <MudPaper Class="pa-8 text-center" Elevation="0" Style="background: #EEF2FF; border-radius: 16px;">
        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
        <MudText Color="Color.Secondary">Žádné veřejné skupiny k zobrazení.</MudText>
    </MudPaper>
}
else
{
    <MudGrid Spacing="3">
        @foreach (var group in _result.Items)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Style="border-radius: 12px;">
                    <MudCardContent>
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">@group.Name</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@group.EntryCount slovíček</MudText>
                        <div class="d-flex align-center gap-2 mt-1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@group.OwnerDisplayName</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@group.SourceLangName ↔ @group.TargetLangName</MudText>
                        </div>
                        @if (!string.IsNullOrEmpty(group.Description))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">@group.Description</MudText>
                        }
                    </MudCardContent>
                    <MudCardActions Class="pa-4 pt-0">
                        <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                   OnClick="@(() => ForkAsync(group.Id))" StartIcon="@Icons.Material.Filled.ContentCopy"
                                   Style="text-transform: none;">Převzít</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>

    @if (_result.TotalCount > _result.PageSize)
    {
        <MudPagination Class="mt-4" Count="@((int)Math.Ceiling((double)_result.TotalCount / _result.PageSize))"
                       Selected="_page" SelectedChanged="PageChanged" />
    }
}

@code {
    private string? _search;
    private PagedResult<GroupListDto>? _result;
    private bool _loading = true;
    private int _page = 1;

    protected override async Task OnInitializedAsync()
    {
        DictState.OnChange += OnDictionaryChanged;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _result = await GroupService.GetPublicGroupsAsync(_search, _page, DictState.SelectedDictionaryId);
        _loading = false;
    }

    private async void OnDictionaryChanged() { _page = 1; await LoadAsync(); await InvokeAsync(StateHasChanged); }

    private async Task HandleSearch(KeyboardEventArgs e) { if (e.Key == "Enter") { _page = 1; await LoadAsync(); } }
    private async Task PageChanged(int page) { _page = page; await LoadAsync(); }

    private async Task ForkAsync(long groupId)
    {
        var result = await GroupService.ForkGroupAsync(groupId);
        if (result != null) { await DictState.LoadAsync(); Snackbar.Add("Skupina převzata!", Severity.Success); }
        else Snackbar.Add("Nepodařilo se převzít skupinu.", Severity.Error);
    }

    public void Dispose() => DictState.OnChange -= OnDictionaryChanged;
}
