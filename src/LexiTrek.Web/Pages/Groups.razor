@page "/groups"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject GroupApiService GroupService
@inject NavigationManager Navigation
@inject IDialogService DialogService

<PageTitle>Moje skupiny - LexiTrek</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Moje skupiny</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/groups/create" Class="mb-4"
           StartIcon="@Icons.Material.Filled.Add">
    Nová skupina
</MudButton>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (!_groups.Any())
{
    <MudAlert Severity="Severity.Info">Zatím nemáte žádné skupiny. Vytvořte si první!</MudAlert>
}
else
{
    <MudGrid>
        @foreach (var group in _groups)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">@group.Name</MudText>
                        <MudText Typo="Typo.body2">@group.WordCount slovíček</MudText>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(group.Visibility == 1 ? Color.Success : Color.Default)">
                            @(group.Visibility == 1 ? "Veřejná" : "Soukromá")
                        </MudChip>
                        @if (!string.IsNullOrEmpty(group.Description))
                        {
                            <MudText Typo="Typo.caption" Class="mt-2">@group.Description</MudText>
                        }
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Size="Size.Small" Color="Color.Primary"
                                   OnClick="@(() => Navigation.NavigateTo($"/groups/{group.Id}"))">
                            Otevřít
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<GroupListDto> _groups = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _groups = await GroupService.GetUserGroupsAsync();
        _loading = false;
    }
}
