@page "/groups"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject GroupApiService GroupService
@inject DictionaryStateService DictState
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Moje skupiny - LexiTrek</PageTitle>

<div class="d-flex align-center justify-space-between mt-4 mb-4">
    <MudText Typo="Typo.h5" Style="font-weight: 700;">Moje skupiny</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/groups/create" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Add" Style="text-transform: none;">
        Nová skupina
    </MudButton>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudGrid Spacing="3">
        @if (DictState.SelectedDictionaryId.HasValue)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Class="group-card cursor-pointer" Style="border-radius: 12px; border-left: 4px solid #4F46E5;"
                         @onclick="@(() => Navigation.NavigateTo($"/dictionaries/{DictState.SelectedDictionaryId}/entries"))">
                    <MudCardContent>
                        <div class="d-flex align-center justify-space-between mb-1">
                            <MudText Typo="Typo.h6" Style="font-weight: 600;">Všechna slovíčka</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.AllInclusive" Size="Size.Small" Color="Color.Primary" />
                        </div>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@(DictState.SelectedDictionary?.EntryCount ?? 0) slovíček</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
        @if (!FilteredGroups.Any())
        {
            <MudItem xs="12" sm="6" md="8">
                <MudPaper Class="pa-6 text-center" Elevation="0" Style="background: #EEF2FF; border-radius: 16px;">
                    <MudText Typo="Typo.h6" Class="mb-1">Zatím žádné vlastní skupiny</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Vytvořte si první skupinu slovíček.</MudText>
                </MudPaper>
            </MudItem>
        }
        @foreach (var group in FilteredGroups)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Class="group-card cursor-pointer" Style="border-radius: 12px;"
                         @onclick="@(() => Navigation.NavigateTo($"/groups/{group.Id}"))">
                    <MudCardContent>
                        <div class="d-flex align-center justify-space-between mb-1">
                            <MudText Typo="Typo.h6" Style="font-weight: 600;">@group.Name</MudText>
                            <MudTooltip Text="@(group.IsPublic ? "Veřejná skupina" : "Soukromá skupina")">
                                <MudIcon Icon="@(group.IsPublic ? Icons.Material.Filled.Public : Icons.Material.Filled.Lock)"
                                         Size="Size.Small" Color="@(group.IsPublic ? Color.Success : Color.Default)" />
                            </MudTooltip>
                        </div>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@group.EntryCount slovíček</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<GroupListDto> _groups = [];
    private bool _loading = true;

    private IEnumerable<GroupListDto> FilteredGroups =>
        DictState.SelectedDictionaryId.HasValue
            ? _groups.Where(g => g.DictionaryId == DictState.SelectedDictionaryId.Value)
            : _groups;

    protected override async Task OnInitializedAsync()
    {
        DictState.OnChange += OnDictionaryChanged;
        _groups = await GroupService.GetUserGroupsAsync();
        _loading = false;
    }

    private void OnDictionaryChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => DictState.OnChange -= OnDictionaryChanged;
}
